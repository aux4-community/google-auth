{
  "scope": "community",
  "name": "google-auth",
  "version": "1.2.0",
  "description": "Authentication for Google Workspace CLI packages",
  "license": "MIT",
  "tags": [
    "google",
    "auth",
    "oauth",
    "google-workspace",
    "gws"
  ],
  "system": [
    [
      "test:gws --version",
      "brew:googleworkspace-cli",
      "npm:@googleworkspace/cli"
    ]
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "google",
          "execute": [
            "profile:google"
          ],
          "help": {
            "text": "Google commands"
          }
        }
      ]
    },
    {
      "name": "google",
      "commands": [
        {
          "name": "auth",
          "execute": [
            "profile:google:auth"
          ],
          "help": {
            "text": "Manage Google authentication"
          }
        },
        {
          "name": "services",
          "execute": [
            "profile:google:services"
          ],
          "help": {
            "text": "List available Google services"
          }
        }
      ]
    },
    {
      "name": "google:auth",
      "commands": [
        {
          "name": "login",
          "execute": [
            "mkdir -p ~/.config/gws && cp -n ${packageDir}/lib/client_secret.json ~/.config/gws/client_secret.json 2>/dev/null || true",
            "nout:if [ -z '${services}' ]; then aux4 google services list --json true; else echo '${services}' | tr ',' '\\n' | while read -r svc; do aux4 google \"$svc\" services 2>/dev/null; done | jq -s '.'; fi | tee /tmp/.aux4-google-services.json | jq -r 'map(.scope) | unique | join(\",\")'",
            "set:scopes=${response}",
            "set:serviceNames=!jq -r 'map(.name) | join(\", \")' /tmp/.aux4-google-services.json",
            "gws auth login --scopes '${scopes}' param(readonly) | jq -r '.message // empty'",
            "nout:gws auth status 2>/dev/null | jq -r '.user'",
            "log:Authenticated as ${response}",
            "log:Services: ${serviceNames}",
            "nout:rm -f /tmp/.aux4-google-services.json"
          ],
          "help": {
            "text": "Authenticate with all installed Google services",
            "variables": [
              {
                "name": "services",
                "text": "Comma-separated services to authorize (default: all installed)",
                "default": ""
              },
              {
                "name": "readonly",
                "text": "Request read-only scopes",
                "default": ""
              },
              {
                "name": "tee",
                "text": "Output login URL to stdout (for agent use)",
                "default": "false",
                "hide": true
              }
            ]
          }
        },
        {
          "name": "status",
          "execute": [
            "gws auth status"
          ],
          "help": {
            "text": "Show current authentication status"
          }
        },
        {
          "name": "logout",
          "execute": [
            "gws auth logout"
          ],
          "help": {
            "text": "Clear saved credentials and token cache"
          }
        }
      ]
    },
    {
      "name": "google:services",
      "commands": [
        {
          "name": "list",
          "execute": [
            "nout:aux4 google --json | jq -r '[.[] | select(.name != \"auth\" and .name != \"services\") | .name] | .[]' | while read -r svc; do aux4 google \"$svc\" services 2>/dev/null; done | jq -s 'unique_by(.name)'",
            "if(json==true) && echo '${response}' || echo '${response}' | jq -r '.[] | \"\\u001b[33m\\(.name)\\u001b[0m\\n  \\(.description)\\n  scope: \\(.scope)\\n\"'"
          ],
          "help": {
            "text": "List available Google services from installed packages",
            "variables": [
              {
                "name": "json",
                "text": "Output as JSON",
                "default": "false",
                "hide": true
              }
            ]
          }
        }
      ]
    }
  ]
}
